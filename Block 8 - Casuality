console.print("\n[bold cyan]═══ ANÁLISE 3: Tendência Temporal Pós-BRIF ═══[/bold cyan]")

panel_pos = panel_model[panel_model["period"] == "post"].copy()

# Converte todas as colunas Int64 nullable para tipos nativos do numpy
for col in panel_pos.columns:
