# 2. FIGURA 1 — SÉRIE TEMPORAL
# ============================================================

console.print("[yellow]→ Fig 1: Série temporal...[/yellow]")

# Agrega por ano
ts_year = (
    panel[panel["period"] != "outside"]
    .groupby(["year", "period"], as_index=False)
    .agg(
        burned_ha_dry   = ("burned_ha",  lambda x: x[panel.loc[x.index,"dry"]==1].mean()),
        burned_ha_wet   = ("burned_ha",  lambda x: x[panel.loc[x.index,"dry"]==0].mean()),
        fire_count_dry  = ("fire_count", lambda x: x[panel.loc[x.index,"dry"]==1].mean()),
        fire_count_wet  = ("fire_count", lambda x: x[panel.loc[x.index,"dry"]==0].mean()),
        precip_dry      = ("precip_mm",  lambda x: x[panel.loc[x.index,"dry"]==1].mean()),
        precip_wet      = ("precip_mm",  lambda x: x[panel.loc[x.index,"dry"]==0].mean()),
    )
    .sort_values("year")
)

fig, axes = plt.subplots(3, 1, figsize=(10, 11), sharex=True)
fig.suptitle(
    "Regime de fogo nas Terras Indígenas do Cerrado (2001–2024)\n"
    "Médias mensais por Terra Indígena",
