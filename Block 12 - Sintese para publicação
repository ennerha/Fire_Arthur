def read_csv_safe(path, required=True):
    path = Path(path)
    if path.exists():
        return pd.read_csv(path)
    if required:
        raise FileNotFoundError(f"Required file not found: {path}")
    return pd.DataFrame()

def read_parquet_safe(path, required=True):
    path = Path(path)
    if path.exists():
        return pd.read_parquet(path)
    if required:
        raise FileNotFoundError(f"Required file not found: {path}")
    return pd.DataFrame()

def normalize_season(df):
    if df is None or df.empty:
        return df
    if "season" in df.columns:
        df["season"] = df["season"].replace({
            "Seca": "dry",
            "Chuvosa": "wet",
            "seca": "dry",
            "chuvosa": "wet",
            "Dry": "dry",
            "Wet": "wet",
        })
    return df

def normalize_period(df):
    if df is None or df.empty:
        return df
    if "period" in df.columns:
        df["period"] = df["period"].replace({
            "Pré": "pre",
            "Pós": "post",
            "Transição": "transition",
            "Pre": "pre",
            "Post": "post",
            "Transition": "transition",
        })
    return df

def zscore(s):
    s = pd.Series(s).astype(float)
    sd = s.std()
    if sd == 0 or np.isnan(sd):
        return pd.Series(np.nan, index=s.index)
    return (s - s.mean()) / sd

def pct_from_logcoef(x):
    return 100 * (np.exp(float(x)) - 1)

def first_existing(paths):
    for p in paths:
        p = Path(p)
        if p.exists():
            return p
    return None

def save_pub_fig(fig, fig_name):
