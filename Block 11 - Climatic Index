def download_oni() -> pd.DataFrame:
    """
    ONI (Oceanic Niño Index) — NOAA CPC
    Anomalia de TSM na região Niño 3.4 (média móvel 3 meses)
    > +0.5°C por 5+ meses = El Niño
    < -0.5°C por 5+ meses = La Niña
    """
    url = "https://www.cpc.ncep.noaa.gov/data/indices/oni.ascii.txt"
    try:
        resp = requests.get(url, timeout=30)
        lines = resp.text.strip().split("\n")
        rows = []
        for line in lines:
            parts = line.split()
            if len(parts) >= 3 and parts[0].isdigit():
                season = parts[1]
                year   = int(parts[0])
                oni    = float(parts[2]) if len(parts) > 2 else np.nan
                # Mapeia estações para meses centrais
                season_map = {
                    "DJF": 1, "JFM": 2, "FMA": 3, "MAM": 4,
                    "AMJ": 5, "MJJ": 6, "JJA": 7, "JAS": 8,
                    "ASO": 9, "SON": 10, "OND": 11, "NDJ": 12,
                }
                month = season_map.get(season, np.nan)
                if not np.isnan(month):
                    rows.append({"year": year, "month": int(month), "oni": oni})
        df = pd.DataFrame(rows).drop_duplicates(["year","month"])
        console.print(f"  [green]✓ ONI: {len(df)} registros ({df['year'].min()}–{df['year'].max()})[/green]")
        return df
    except Exception as e:
        console.print(f"  [yellow]⚠ ONI falhou ({e}), usando dados embutidos...[/yellow]")
        return _oni_embedded()

def _oni_embedded() -> pd.DataFrame:
    """ONI histórico embutido para 2001-2024 (valores anuais médios conhecidos)."""
    # Dados anuais médios do ONI — fonte NOAA
    oni_annual = {
        2001: 0.0, 2002: 0.8, 2003: 0.2, 2004: 0.5, 2005: 0.2,
        2006: 0.3, 2007:-0.5, 2008:-0.5, 2009: 0.5, 2010:-1.2,
        2011:-0.9, 2012: 0.1, 2013:-0.2, 2014: 0.4, 2015: 1.5,
        2016: 0.5, 2017:-0.3, 2018: 0.7, 2019: 0.4, 2020: 0.2,
        2021:-0.7, 2022:-0.9, 2023: 1.0, 2024: 0.5,
    }
    rows = []
    for year, oni in oni_annual.items():
        for month in range(1, 13):
            rows.append({"year": year, "month": month, "oni": oni})
    return pd.DataFrame(rows)

def download_pdo() -> pd.DataFrame:
    """
    PDO (Pacific Decadal Oscillation) — NOAA NCEI
    Índice mensal de variabilidade multidecadal do Pacífico Norte
    """
    url = "https://www.ncei.noaa.gov/pub/data/cmb/ersst/v5/index/ersst.v5.pdo.dat"
    try:
        resp = requests.get(url, timeout=30)
        lines = [l for l in resp.text.strip().split("\n")
                 if l.strip() and not l.startswith("Year")]
        rows = []
        for line in lines:
            parts = line.split()
            if len(parts) >= 13 and parts[0].isdigit():
                year = int(parts[0])
                for m, val in enumerate(parts[1:13], 1):
                    try:
                        pdo = float(val)
                        if pdo != 99.99:
                            rows.append({"year": year, "month": m, "pdo": pdo})
                    except:
                        pass
        df = pd.DataFrame(rows)
        console.print(f"  [green]✓ PDO: {len(df)} registros ({df['year'].min()}–{df['year'].max()})[/green]")
        return df
    except Exception as e:
        console.print(f"  [yellow]⚠ PDO não disponível: {e}[/yellow]")
        return pd.DataFrame(columns=["year","month","pdo"])

def download_amo() -> pd.DataFrame:
    """
    AMO (Atlantic Multidecadal Oscillation) — NOAA ESRL
    Variabilidade de TSM no Atlântico Norte — relevante para precipitação no Cerrado
    """
    url = "https://psl.noaa.gov/data/correlation/amon.us.long.data"
    try:
        resp = requests.get(url, timeout=30)
        lines = resp.text.strip().split("\n")
        rows = []
        for line in lines:
            parts = line.split()
            if len(parts) >= 13 and parts[0].isdigit():
                year = int(parts[0])
                for m, val in enumerate(parts[1:13], 1):
                    try:
                        amo = float(val)
                        if abs(amo) < 10:
                            rows.append({"year": year, "month": m, "amo": amo})
                    except:
                        pass
        df = pd.DataFrame(rows)
        console.print(f"  [green]✓ AMO: {len(df)} registros ({df['year'].min()}–{df['year'].max()})[/green]")
        return df
    except Exception as e:
        console.print(f"  [yellow]⚠ AMO não disponível: {e}[/yellow]")
        return pd.DataFrame(columns=["year","month","amo"])

