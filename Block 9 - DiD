did_results = []

def run_did_model(dep_var, dep_label, formula_extra="", model_name="DiD"):
    formula = (f"{dep_var} ~ post + treated + post_x_treated + "
               f"dry + post_x_dry + dry_x_treated + post_x_dry_x_treat + "
               f"precip_mm + C(month_int) + C(ti_id_str) - 1 {formula_extra}")
    try:
        m = smf.ols(formula, data=panel_did).fit(
            cov_type="cluster",
            cov_kwds={"groups": panel_did["ti_id_str"]}
        )

        key_vars = ["post_x_treated", "post_x_dry", "post_x_dry_x_treat"]
        console.print(f"\n  [cyan]{model_name} вЂ” {dep_label}[/cyan]")
        for v in key_vars:
            if v in m.params:
                sig = ("***" if m.pvalues[v]<0.001 else "**" if m.pvalues[v]<0.01
                       else "*" if m.pvalues[v]<0.05 else "n.s.")
                console.print(
                    f"    {v:30s}: ОІ={m.params[v]:+.4f} "
                    f"(SE={m.bse[v]:.4f}) p={m.pvalues[v]:.4f} {sig}"
                )

        for v in key_vars:
            if v in m.params:
                ci = m.conf_int().loc[v]
                did_results.append({
                    "model":    model_name,
                    "dep_var":  dep_var,
                    "dep_label":dep_label,
                    "variable": v,
                    "coef":     m.params[v],
                    "se":       m.bse[v],
                    "pvalue":   m.pvalues[v],
                    "ci_low":   ci[0],
                    "ci_high":  ci[1],
                    "sig":      ("***" if m.pvalues[v]<0.001 else "**" if m.pvalues[v]<0.01
                                 else "*" if m.pvalues[v]<0.05 else "n.s."),
                    "r2":       m.rsquared,
                    "n_obs":    int(m.nobs),
                })
        return m
    except Exception as e:
        console.print(f"  [red]вњ— {model_name} {dep_label}: {e}[/red]")
        return None

