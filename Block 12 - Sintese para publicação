                console.print(f"  [green]✓ {fname}[/green]")
            else:
                console.print(f"  [yellow]⚠ Não encontrado: {fname}[/yellow]")

    # ── Consolida CSVs ────────────────────────────────────────────────────────
    nti_csvs = sorted(EXPORT_LOCAL_NTI.glob(f"{TASK_PREFIX_NTI}_*.csv"))
    if nti_csvs:
        nti_dfs = []
        for f in nti_csvs:
            df_tmp = pd.read_csv(f)
            drop   = [c for c in df_tmp.columns
                      if c.startswith("system:") or c in (".geo","geo")]
            df_tmp = df_tmp.drop(columns=drop, errors="ignore")

            # Identifica colunas de mês (burned_m01 ... burned_m12)
            month_cols = [c for c in df_tmp.columns if c.startswith("burned_m")]

            if month_cols and "year" in df_tmp.columns:
                # Converte de wide para long
                df_long = df_tmp.melt(
                    id_vars=["year"],
                    value_vars=month_cols,
                    var_name="month_col",
                    value_name="burned_pixels"
                )
                df_long["month"] = df_long["month_col"].str.extract(r"(\d+)").astype(int)
                df_long = df_long.drop(columns=["month_col"])
                # Agrega células do grid por mês (soma)
                df_long = (
                    df_long
                    .groupby(["year","month"], as_index=False)
                    .agg(burned_pixels=("burned_pixels","sum"))
                )
                nti_dfs.append(df_long)
            else:
                console.print(f"  [yellow]⚠ Formato inesperado: {f.name}[/yellow]")

        if nti_dfs:
            nti_df = pd.concat(nti_dfs, ignore_index=True)
            nti_df["year"]          = pd.to_numeric(nti_df["year"],  errors="coerce").astype("Int64")
            nti_df["month"]         = pd.to_numeric(nti_df["month"], errors="coerce").astype("Int64")
            nti_df["burned_pixels"] = pd.to_numeric(nti_df["burned_pixels"], errors="coerce").fillna(0)
            nti_df["burned_ha"]     = nti_df["burned_pixels"] * 0.09
            nti_df["region"]        = "cerrado_native_non_indigenous"

            def _period(y):
                y = int(y) if not pd.isna(y) else 0
                if 2003 <= y <= 2012: return "pre"
                if y == 2013:         return "transition"
                if 2014 <= y <= 2023: return "post"
                return "outside"
            def _season(m):
                return "dry" if int(m) in [5,6,7,8,9,10] else "wet"

