if ratio_data:
    ratio_df = pd.concat(ratio_data, ignore_index=True)
    ratio_df["log_ratio"] = np.log1p(
        ratio_df["burned_per_hotspot"].replace([np.inf, -np.inf], np.nan)
    )
    ratio_df = ratio_df.dropna(subset=["log_ratio"])

    pre_vals = ratio_df.loc[ratio_df["Period"] == "Pre-BRIF", "log_ratio"]
