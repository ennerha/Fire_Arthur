# Elipse de confiança para scatter
def confidence_ellipse(x, y, ax, n_std=1.5, **kwargs):
    if len(x) < 3:
        return
    cov = np.cov(x, y)
    pearson = cov[0,1] / np.sqrt(cov[0,0] * cov[1,1])
    rx = np.sqrt(1 + pearson)
    ry = np.sqrt(1 - pearson)
    ellipse = Ellipse((0,0), width=rx*2, height=ry*2, **kwargs)
    sx = np.sqrt(cov[0,0]) * n_std
    sy = np.sqrt(cov[1,1]) * n_std
    transf = transforms.Affine2D().rotate_deg(45).scale(sx,sy).translate(np.mean(x), np.mean(y))
    ellipse.set_transform(transf + ax.transData)
    return ax.add_patch(ellipse)

