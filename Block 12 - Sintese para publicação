                     "pvalue":r2["pvalue"],"sig":r2["sig"],"color":C_POST})
    # Trend
    r3 = trend_df[(trend_df["model"]=="Linear") &
                  (trend_df["season"].isin(["Seca","dry"])) &
                  (trend_df["dep_var"]==dep_var)]
