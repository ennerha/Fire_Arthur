def ckpt_path(name: str) -> Path:
    return CHECKPOINT_DIR / f"{name}.pkl"

def ckpt_exists(name: str) -> bool:
    return ckpt_path(name).exists()

def ckpt_save(name: str, obj):
    with open(ckpt_path(name), "wb") as f:
        pickle.dump(obj, f)
    console.print(f"  [dim]✓ Checkpoint salvo: {name}[/dim]")

def ckpt_load(name: str):
    with open(ckpt_path(name), "rb") as f:
        obj = pickle.load(f)
    console.print(f"  [dim]→ Checkpoint carregado: {name}[/dim]")
    return obj

def ckpt_load_or_run(name: str, func, force: bool = False):
    """Carrega checkpoint se existir, senão executa func e salva."""
    if not force and ckpt_exists(name):
        return ckpt_load(name)
    result = func()
    if result is not None:
        ckpt_save(name, result)
    return result

