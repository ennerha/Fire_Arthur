def find_boundary_file() -> Path:
    search_roots = [PROJECT_ROOT, Path("/content/drive/MyDrive")]
    candidates = []

    for root in search_roots:
        if root.exists():
            for ext in ["*.shp", "*.gpkg", "*.geojson", "*.json"]:
                candidates.extend(list(root.rglob(ext)))

    candidates = list(dict.fromkeys(candidates))

    if not candidates:
        raise FileNotFoundError(
            "Nenhum arquivo de limites encontrado no Google Drive.\n"
            "Faça upload de um .shp/.gpkg/.geojson com as Terras Indígenas."
        )

    keywords = ["terra", "indig", "indigena", "indígena", "ti", "cerrado", "funai", "study"]
    scored = []
    for f in candidates:
        name = str(f).lower()
        score = sum(k in name for k in keywords)
        if "study_area_dissolved" in name:
            score -= 2
        if "study_tis" in name:
            score += 2
        scored.append((score, f))

    scored.sort(key=lambda x: x[0], reverse=True)

    console.print("[cyan]Candidatos encontrados:[/cyan]")
    for score, f in scored[:15]:
        console.print(f"  score={score} | {f}")

    return scored[0][1]

def detect_name_field(gdf) -> str:
    for col in POSSIBLE_NAME_FIELDS:
        if col in gdf.columns:
            return col
    text_cols = [c for c in gdf.columns
                 if c != "geometry" and gdf[c].dtype == "object"]
    if text_cols:
        return text_cols[0]
    gdf["ti_name_auto"] = [f"TI_{i+1:02d}" for i in range(len(gdf))]
    return "ti_name_auto"

def prepare_boundaries():
    global TI_VECTOR_PATH

    # 1. Se nenhum caminho foi definido, tenta baixar automaticamente
    if TI_VECTOR_PATH is None:
        console.print("[yellow]TI_VECTOR_PATH não definido — tentando download automático...[/yellow]")
        try:
            downloaded = download_terras_indigenas(filter_cerrado=True)
            TI_VECTOR_PATH = str(downloaded)
            console.print(f"[green]✓ Download automático concluído:[/green] {TI_VECTOR_PATH}")
        except Exception as download_err:
            console.print(f"[red]Download automático falhou: {download_err}[/red]")
            console.print("[yellow]Tentando auto-detecção de arquivo existente no Drive...[/yellow]")
            try:
                found = find_boundary_file()
                TI_VECTOR_PATH = str(found)
            except FileNotFoundError:
                raise FileNotFoundError(
                    "Não foi possível baixar nem encontrar um arquivo de Terras Indígenas.\n"
                    "Opções:\n"
                    "  1. Verifique sua conexão com a internet e rode novamente.\n"
                    "  2. Faça upload manual de um .gpkg/.shp/.geojson para:\n"
                    f"     {DIRS['raw']}\n"
                    "  3. Defina TI_VECTOR_PATH manualmente no início do script."
                )

    vector_path = Path(TI_VECTOR_PATH)
    if not vector_path.exists():
        raise FileNotFoundError(f"Arquivo não encontrado: {vector_path}")

    console.print(f"[green]✓ Usando arquivo de limites:[/green] {vector_path}")

    gdf = gpd.read_file(vector_path)
    gdf = gdf[gdf.geometry.notnull()].copy()

    if gdf.empty:
        raise ValueError("O arquivo foi lido, mas não contém geometrias válidas.")

    if gdf.crs is None:
        console.print("[yellow]Aviso: CRS ausente. Assumindo EPSG:4326.[/yellow]")
        gdf = gdf.set_crs("EPSG:4326")
    gdf = gdf.to_crs("EPSG:4326")

    name_field = detect_name_field(gdf)
    console.print(f"[green]✓ Campo de nome detectado:[/green] {name_field}")

    gdf["ti_name"] = gdf[name_field].astype(str)
    gdf["ti_id"]   = np.arange(1, len(gdf) + 1)
    gdf["geometry"] = gdf.geometry.buffer(0)
    gdf = gdf[~gdf.geometry.is_empty].copy()

    gdf_area = gdf.to_crs(AREA_CRS)
    gdf["area_ha"]  = gdf_area.geometry.area / 10_000
    gdf["area_km2"] = gdf_area.geometry.area / 1_000_000

    study_area = gdf.dissolve()
    study_area["name"] = "study_area_indigenous_lands"

    out_ti   = DIRS["boundaries"] / "study_tis_cerrado.gpkg"
    out_area = DIRS["boundaries"] / "study_area_dissolved.gpkg"

    gdf.to_file(out_ti, driver="GPKG")
    study_area.to_file(out_area, driver="GPKG")
    gdf.to_file(DIRS["boundaries"] / "study_tis_cerrado.geojson",   driver="GeoJSON")
    study_area.to_file(DIRS["boundaries"] / "study_area_dissolved.geojson", driver="GeoJSON")

    console.print(f"[green]✓ Terras Indígenas salvas:[/green] {out_ti}")
    console.print(f"[green]✓ Área de estudo dissolvida:[/green] {out_area}")

    return gdf, study_area

