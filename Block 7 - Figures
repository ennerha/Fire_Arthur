# ============================================================
# 4. FIGURA 3 — COEFICIENTES DO MODELO
# ============================================================

console.print("[yellow]→ Fig 3: Coeficientes...[/yellow]")

key_vars = ["post", "dry", "post_x_dry", "precip_mm"]
var_labels = {
    "post":       "Pós-BRIF",
    "dry":        "Estação Seca",
    "post_x_dry": "Pós-BRIF ×\nEstação Seca\n(efeito-chave)",
    "precip_mm":  "Precipitação (mm)",
}

df_coef = results[
    (results["model"] == "OLS_FE_month") &
    (results["variable"].isin(key_vars))
].copy()
df_coef["label"] = df_coef["variable"].map(var_labels)

fig, axes = plt.subplots(1, 2, figsize=(11, 5))
fig.suptitle(
    "Coeficientes do modelo OLS com efeitos fixos por Terra Indígena\n"
    "Intervalo de confiança 95% — erros padrão clusterizados por TI",
    fontsize=11, fontweight="bold"
)

dep_vars = [
    ("log_burned_ha",  "Log Área Queimada (ha)"),
    ("log_fire_count", "Log Focos de Calor"),
]

for ax, (dep_var, dep_label) in zip(axes, dep_vars):
    df_p = df_coef[df_coef["dep_var"] == dep_var].sort_values("coef")

    colors_bar = [
        C_POST if v == "post_x_dry" else
        C_DRY  if v == "dry" else
        C_PRE  if v == "post" else "#607D8B"
        for v in df_p["variable"]
    ]

    yerr = np.array([
        df_p["coef"].values - df_p["ci_low"].values,
        df_p["ci_high"].values - df_p["coef"].values,
    ])

    ax.barh(
        df_p["label"], df_p["coef"],
        xerr=yerr, color=colors_bar, alpha=0.85,
        error_kw={"elinewidth": 1.5, "capsize": 5, "ecolor": "black"}
    )

    ax.axvline(0, color="black", linewidth=0.8, linestyle="--")
    ax.set_title(dep_label, fontsize=10)
    ax.set_xlabel("Coeficiente (β)", fontsize=9)

    for i, (_, row) in enumerate(df_p.iterrows()):
        sig = row["sig"]
        x   = row["ci_high"] + abs(row["ci_high"]) * 0.05
        ax.text(x, i, sig or f"p={row['pvalue']:.2f}",
                va="center", fontsize=8.5,
                color="darkred" if sig else "gray")

plt.tight_layout()
p = DIRS["figures"] / "fig3_coeficientes_modelo.png"
fig.savefig(p, dpi=DPI_PUB, bbox_inches="tight")
plt.close()
