# ============================================================
# 3. RECORRÊNCIA INTERANUAL (reburning)
# ============================================================

def compute_reburning(metrics: pd.DataFrame) -> pd.DataFrame:
    """
    Para cada TI, calcula a frequência com que um mesmo ano
    teve fogo depois de ter tido fogo no ano anterior.
    Retorna coluna reburning_rate por TI × período.
    """
    rows = []
    for ti_id, grp in metrics.groupby("ti_id"):
        grp = grp.sort_values("year")
        had_fire      = (grp["burned_ha_total"] > 0).astype(int).values
        # reburning: ano com fogo após ano com fogo
        reburning     = np.sum((had_fire[1:] == 1) & (had_fire[:-1] == 1))
        possible      = np.sum(had_fire[:-1] == 1)
        reburning_rate = reburning / possible if possible > 0 else np.nan
        rows.append({"ti_id": ti_id, "reburning_rate": reburning_rate})
    return pd.DataFrame(rows)


reburning_df = compute_reburning(metrics)
metrics = metrics.merge(reburning_df, on="ti_id", how="left")

# ============================================================
# 4. FIRE REGIME REORGANIZATION INDEX (FRRI)
# ============================================================

def compute_frri(metrics: pd.DataFrame,
                 pre_period: tuple,
                 post_period: tuple) -> pd.DataFrame:
    """
    FRRI com 5 componentes conforme fluxograma:

    C1 — Redução do fogo crítico (área queimada na seca)
    C2 — Redistribuição sazonal (queda na fração seca/total)
    C3 — Redução da área queimada total
    C4 — Fragmentação/recorrência (redução do CV mensal e reburning)
    C5 — Independência climática (C1 ajustado pela precipitação)

    Escala: valores positivos = reorganização favorável
    FRRI ∈ [-1, 1] aproximadamente
    """
    pre  = metrics[metrics["year"].between(*pre_period)]
    post = metrics[metrics["year"].between(*post_period)]

    rows = []

    for ti_id in metrics["ti_id"].unique():
        pre_ti  = pre[pre["ti_id"]  == ti_id]
        post_ti = post[post["ti_id"] == ti_id]

        if pre_ti.empty or post_ti.empty:
            continue

        ti_name  = metrics[metrics["ti_id"] == ti_id]["ti_name"].iloc[0]
        area_ha  = metrics[metrics["ti_id"] == ti_id]["area_ha"].iloc[0]
        reb_rate = metrics[metrics["ti_id"] == ti_id]["reburning_rate"].iloc[0]

        # Médias por período
        p = {
            "pre_burned_dry":    pre_ti["burned_ha_dry"].mean(),
            "post_burned_dry":   post_ti["burned_ha_dry"].mean(),
            "pre_burned_total":  pre_ti["burned_ha_total"].mean(),
            "post_burned_total": post_ti["burned_ha_total"].mean(),
            "pre_dry_frac":      pre_ti["burned_dry_frac"].mean(),
            "post_dry_frac":     post_ti["burned_dry_frac"].mean(),
            "pre_precip_dry":    pre_ti["precip_dry_mm"].mean(),
            "post_precip_dry":   post_ti["precip_dry_mm"].mean(),
            "pre_frag_cv":       pre_ti["fragmentation_cv"].mean(),
            "post_frag_cv":      post_ti["fragmentation_cv"].mean(),
            "pre_months_fire":   pre_ti["months_with_fire_dry"].mean(),
            "post_months_fire":  post_ti["months_with_fire_dry"].mean(),
        }

        def rel_change(pre_val, post_val):
            """Mudança relativa: positivo = redução (reorganização)."""
            if pre_val > 0 and not np.isnan(pre_val):
                return (pre_val - post_val) / pre_val
            return np.nan

        # C1: redução do fogo crítico (seco)
        c1 = rel_change(p["pre_burned_dry"], p["post_burned_dry"])

        # C2: redistribuição sazonal (queda na fração seca)
        c2 = rel_change(p["pre_dry_frac"], p["post_dry_frac"])

        # C3: redução da área total queimada
        c3 = rel_change(p["pre_burned_total"], p["post_burned_total"])

        # C4: fragmentação + recorrência
        # Queda no CV mensal (fogo mais distribuído = mais fragmentado = mais manejado)
        # + reburning rate (quanto menor, melhor)
        c4_frag = rel_change(p["pre_frag_cv"], p["post_frag_cv"]) * -1  # menor CV = mais fragmentado
        c4_reb  = (1 - reb_rate) if not np.isnan(reb_rate) else np.nan   # menos reburning = melhor
        c4_vals = [v for v in [c4_frag, c4_reb] if not np.isnan(v)]
        c4 = np.mean(c4_vals) if c4_vals else np.nan

        # C5: independência climática
        # C1 ajustado: se precipitação caiu mas fogo também caiu → efeito real
        precip_ratio = (p["post_precip_dry"] / p["pre_precip_dry"]
                        if p["pre_precip_dry"] > 0 else 1.0)
        c5 = c1 / precip_ratio if (not np.isnan(c1) and precip_ratio > 0) else np.nan

        # Clipa componentes
        def clip(v, lo=-1, hi=1):
            return float(np.clip(v, lo, hi)) if not np.isnan(v) else np.nan

        comps = {
            "c1_fogo_critico":    clip(c1),
            "c2_redistribuicao":  clip(c2),
            "c3_area_total":      clip(c3),
            "c4_fragmentacao":    clip(c4),
            "c5_clima_adj":       clip(c5, -2, 2),
        }

        # Pesos: C1 e C2 têm maior peso (hipóteses centrais H2 e H3)
        weights = {"c1_fogo_critico": 0.30, "c2_redistribuicao": 0.25,
                   "c3_area_total":   0.20, "c4_fragmentacao":   0.15,
                   "c5_clima_adj":    0.10}

        frri_num = frri_den = 0
        for k, w in weights.items():
            v = comps[k]
            if not np.isnan(v):
                frri_num += v * w
                frri_den += w

        frri = round(frri_num / frri_den, 4) if frri_den > 0 else np.nan

        rows.append({
            "ti_id":   ti_id,
            "ti_name": ti_name,
            "area_ha": area_ha,
            **comps,
            "frri":                    frri,
            "reburning_rate":          round(reb_rate, 4) if not np.isnan(reb_rate) else np.nan,
            "pre_burned_ha_dry":       round(p["pre_burned_dry"],    2),
            "post_burned_ha_dry":      round(p["post_burned_dry"],   2),
            "pre_burned_ha_total":     round(p["pre_burned_total"],  2),
            "post_burned_ha_total":    round(p["post_burned_total"], 2),
            "pre_burned_dry_frac":     round(p["pre_dry_frac"],  4) if not np.isnan(p["pre_dry_frac"])  else np.nan,
            "post_burned_dry_frac":    round(p["post_dry_frac"], 4) if not np.isnan(p["post_dry_frac"]) else np.nan,
            "pre_precip_dry_mm":       round(p["pre_precip_dry"],  2),
            "post_precip_dry_mm":      round(p["post_precip_dry"], 2),
        })

    df = pd.DataFrame(rows).sort_values("frri", ascending=False).reset_index(drop=True)
    return df


