def period_label(year):
    year = int(year)
    if PRE_PERIOD[0] <= year <= PRE_PERIOD[1]:
        return "pre"
    if year == TRANSITION_YEAR:
        return "transition"
    if POST_PERIOD[0] <= year <= POST_PERIOD[1]:
        return "post"
    return "outside"

def season_label(month):
    return "dry" if int(month) in DRY_MONTHS else "wet"

def add_time_fields(df):
    df = df.copy()
    df["year"]  = df["year"].astype(int)
    df["month"] = df["month"].astype(int)
    df["date"]  = pd.to_datetime(dict(year=df["year"], month=df["month"], day=1))
    df["period"]    = df["year"].apply(period_label)
    df["season"]    = df["month"].apply(season_label)
    df["post"]      = (df["period"] == "post").astype(int)
    df["dry"]       = (df["season"] == "dry").astype(int)
    df["post_x_dry"] = df["post"] * df["dry"]
    return df

def month_panel():
    rows = [{"year": y, "month": m}
            for y in range(START_YEAR, END_YEAR + 1)
            for m in range(1, 13)]
    return pd.DataFrame(rows)

