# ============================================================
# 3. FEATURECOLLECTION VIA BBOXES (funciona sem upload)
# ============================================================

def build_tis_fc() -> ee.FeatureCollection:
    """Bboxes das TIs em lotes de 50 — payload mínimo, preciso para CHIRPS 5.5km."""
    features = []
    for _, row in tis.iterrows():
        minx, miny, maxx, maxy = row.geometry.bounds
        features.append(ee.Feature(
            ee.Geometry.Rectangle([minx, miny, maxx, maxy]),
            {"ti_id": int(row["ti_id"]), "ti_name": str(row["ti_name"]),
             "area_ha": float(row["area_ha"]), "area_km2": float(row["area_km2"])}
        ))

    batches = [features[i:i+50] for i in range(0, len(features), 50)]
    fc = ee.FeatureCollection(
        [ee.FeatureCollection(b) for b in batches]
    ).flatten()
    console.print(f"[green]✓ FeatureCollection: {fc.size().getInfo()} TIs (bboxes)[/green]")
    return fc

# ============================================================
# 4. EXPORT TASKS
# ============================================================

def launch_tasks(tis_fc, years=None) -> dict:
    if years is None:
        years = list(range(START_YEAR, END_YEAR + 1))

    chirps = ee.ImageCollection(CHIRPS_COLLECTION)
    tasks  = {}

    for year in years:
        dest = EXPORT_LOCAL_DIR / f"{TASK_PREFIX}_{year}.csv"
        if dest.exists() and not FORCE_REPROCESS:
            console.print(f"[cyan]✓ CSV já existe localmente: {dest.name}[/cyan]")
            continue

        month_fcs = []
        for month in range(1, 13):
            start = ee.Date.fromYMD(year, month, 1)
            img = chirps.filterDate(start, start.advance(1, "month")).sum().rename("precip_mm")
            reduced = img.reduceRegions(
                collection=tis_fc,
                reducer=ee.Reducer.mean().setOutputs(["precip_mm"]),
                scale=CHIRPS_SCALE,
                tileScale=EE_TILE_SCALE,
            ).map(lambda f: f.set("year", year).set("month", month)
                             .select(["ti_id", "ti_name", "area_ha", "area_km2",
                                      "year", "month", "precip_mm"]))
            month_fcs.append(reduced)

        task = ee.batch.Export.table.toDrive(
            collection     = ee.FeatureCollection(month_fcs).flatten(),
            description    = f"{TASK_PREFIX}_{year}",
            folder         = EE_EXPORT_FOLDER,
            fileNamePrefix = f"{TASK_PREFIX}_{year}",
            fileFormat     = "CSV",
        )
        task.start()
        tasks[year] = task
        console.print(f"[yellow]→ Task: {TASK_PREFIX}_{year}[/yellow]")
        time.sleep(0.3)

    return tasks


def monitor_tasks(tasks: dict) -> dict:
    if not tasks:
        return {}

    console.print(f"[cyan]Monitorando {len(tasks)} tasks...[/cyan]")
    t0, done = time.time(), {}

    while tasks:
        pending = {}
        for year, task in tasks.items():
            state = task.status()["state"]
            if state in ("COMPLETED", "FAILED", "CANCELLED"):
                done[year] = state
                color = "green" if state == "COMPLETED" else "red"
                console.print(f"  [{color}]{'✓' if state=='COMPLETED' else '✗'} {year}: {state}[/{color}]")
            else:
                pending[year] = task
        tasks = pending
        if not tasks:
            break
        if time.time() - t0 > MONITOR_TIMEOUT:
            for y in tasks:
                done[y] = "TIMEOUT"
            break
        console.print(f"  [dim]{len(done)}/{len(done)+len(tasks)} | {len(tasks)} pendentes | {MONITOR_INTERVAL}s...[/dim]")
        time.sleep(MONITOR_INTERVAL)

    ok  = sum(1 for s in done.values() if s == "COMPLETED")
    bad = [y for y, s in done.items() if s != "COMPLETED"]
    console.print(f"[bold]Resultado: {ok} OK | {len(bad)} problema(s)[/bold]")
    if bad:
        console.print(f"[red]Problemas: {bad}[/red]")
    return done

# ============================================================
# 5. BAIXA CSVs VIA GOOGLE DRIVE API (não filesystem)
# ============================================================

def get_drive_service():
    """Autentica e retorna o serviço da Google Drive API."""
    auth.authenticate_user()
    return build("drive", "v3", cache_discovery=False)


def download_csvs_from_drive(years: list) -> dict:
    """
    Busca e baixa os CSVs exportados pelo EE usando a Drive API.
    Retorna dict {year: Path} com os arquivos baixados.
    """
    svc = get_drive_service()
    downloaded = {}
    years_needed = set(str(y) for y in years)

    console.print("[yellow]→ Buscando CSVs via Google Drive API...[/yellow]")

    # Busca por nome de arquivo
    for year in years:
        filename = f"{TASK_PREFIX}_{year}.csv"
        dest = EXPORT_LOCAL_DIR / filename

        if dest.exists() and not FORCE_REPROCESS:
            console.print(f"  [cyan]✓ Já baixado: {filename}[/cyan]")
            downloaded[year] = dest
            continue

        # Query na Drive API
        query = f"name='{filename}' and mimeType='text/csv' and trashed=false"
        results = svc.files().list(
            q=query,
            spaces="drive",
            fields="files(id, name, parents)",
        ).execute()

        files = results.get("files", [])

        if not files:
            console.print(f"  [yellow]⚠ Não encontrado: {filename}[/yellow]")
            continue

        file_id = files[0]["id"]
        console.print(f"  [dim]Baixando: {filename} (id={file_id})[/dim]")

        request = svc.files().get_media(fileId=file_id)
        buf = io.BytesIO()
        downloader = MediaIoBaseDownload(buf, request)
        done_dl = False
        while not done_dl:
            _, done_dl = downloader.next_chunk()

        dest.write_bytes(buf.getvalue())
        downloaded[year] = dest
        console.print(f"  [green]✓ Baixado: {filename}[/green]")

    console.print(f"[green]✓ {len(downloaded)}/{len(years)} CSVs baixados.[/green]")
    return downloaded

