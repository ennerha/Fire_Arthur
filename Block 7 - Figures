# 6. FIGURA 5 — DIVERGÊNCIA HOTSPOTS vs ÁREA QUEIMADA
# ============================================================

console.print("[yellow]→ Fig 5: Divergência hotspots vs área queimada...[/yellow]")

# Agrega por ano — apenas seca
ts_dry = (
    panel[
        (panel["season"] == "dry") &
        (panel["period"].isin(["pre", "post", "transition"]))
    ]
    .groupby("year", as_index=False)
    .agg(
        burned_ha_mean  = ("burned_ha",  "mean"),
        fire_count_mean = ("fire_count", "mean"),
    )
    .sort_values("year")
)

# Normaliza (z-score) para comparar na mesma escala
for col in ["burned_ha_mean", "fire_count_mean"]:
    mu  = ts_dry[col].mean()
    std = ts_dry[col].std()
    ts_dry[f"{col}_z"] = (ts_dry[col] - mu) / std

fig, ax = plt.subplots(figsize=(11, 5))

ax.plot(ts_dry["year"], ts_dry["burned_ha_mean_z"],
        color=C_BURNED, linewidth=2.5, marker="o", markersize=5,
        label="Área queimada (z-score)")
ax.plot(ts_dry["year"], ts_dry["fire_count_mean_z"],
        color=C_FIRE,   linewidth=2.5, marker="s", markersize=5,
        linestyle="--", label="Focos de calor (z-score)")

ax.fill_between(ts_dry["year"],
                ts_dry["burned_ha_mean_z"],
                ts_dry["fire_count_mean_z"],
                alpha=0.15, color="purple",
                label="Divergência entre métricas")

ax.axvspan(2001, 2012.5, alpha=0.05, color=C_PRE)
ax.axvspan(2012.5, 2013.5, alpha=0.1, color=C_TRANS)
ax.axvspan(2013.5, 2024, alpha=0.05, color=C_POST)
ax.axvline(2012.5, color=C_TRANS, linewidth=1.2, linestyle="--", alpha=0.7)
ax.axvline(2013.5, color=C_TRANS, linewidth=1.2, linestyle="--", alpha=0.7)
ax.axhline(0, color="black", linewidth=0.6, linestyle=":")

ax.set_title(
    "Divergência entre focos de calor e área queimada na estação seca\n"
    "Evidência de que hotspots não capturam o regime de fogo",
    fontsize=11, fontweight="bold"
)
ax.set_xlabel("Ano", fontsize=10)
ax.set_ylabel("Valor padronizado (z-score)", fontsize=10)
ax.legend(fontsize=9, loc="upper left")
ax.grid(axis="y", alpha=0.25)

ymax = ax.get_ylim()[1]
ax.text(2006.5, ymax * 0.88, "Pré-BRIF", fontsize=8, color=C_PRE,  ha="center", style="italic")
ax.text(2013,   ymax * 0.88, "Trans.",   fontsize=7, color=C_TRANS, ha="center", style="italic")
ax.text(2018.5, ymax * 0.88, "Pós-BRIF",fontsize=8, color=C_POST,  ha="center", style="italic")

ax.set_xlim(2001, 2024)
ax.xaxis.set_major_locator(mticker.MultipleLocator(2))

plt.tight_layout()
p = DIRS["figures"] / "fig5_divergencia_metricas.png"
fig.savefig(p, dpi=DPI_PUB, bbox_inches="tight")
plt.close()
