def download_terras_indigenas(filter_cerrado: bool = True) -> Path:
    """
    Baixa as Terras Indígenas do TerraBrasilis (INPE/FUNAI) via WFS.
    Tenta as URLs em TI_DOWNLOAD_URLS em ordem.
    Se filter_cerrado=True, mantém apenas as TIs que intersectam o bbox do Cerrado.
    Retorna o Path do arquivo .gpkg salvo em 00_raw/.
    """
    gpkg_out = DIRS["raw"] / "terras_indigenas_funai.gpkg"

    if gpkg_out.exists() and not FORCE_REPROCESS:
        console.print(f"[cyan]✓ Arquivo já existe, pulando download:[/cyan] {gpkg_out.name}")
        return gpkg_out

    geojson_out = DIRS["raw"] / "terras_indigenas_funai_raw.geojson"
    gdf = None
    last_error = None

    for i, url in enumerate(TI_DOWNLOAD_URLS, 1):
        console.print(f"[yellow]→ Tentativa {i}/{len(TI_DOWNLOAD_URLS)}: baixando TIs...[/yellow]")
        console.print(f"   URL: {url[:80]}...")
        try:
            urllib.request.urlretrieve(url, geojson_out)
            gdf = gpd.read_file(geojson_out)
            console.print(f"[green]✓ Download OK — {len(gdf)} feições carregadas.[/green]")
            break
        except Exception as e:
            last_error = e
            console.print(f"[red]✗ Falhou: {e}[/red]")

    if gdf is None:
        raise RuntimeError(
            f"Todas as tentativas de download falharam.\n"
            f"Último erro: {last_error}\n"
            f"Faça o upload manual de um .gpkg/.shp/.geojson para:\n"
            f"  {DIRS['raw']}\n"
            f"e defina TI_VECTOR_PATH no início do script."
        )

    console.print(f"[cyan]Colunas disponíveis:[/cyan] {list(gdf.columns)}")

    # Garante CRS geográfico
    if gdf.crs is None:
        gdf = gdf.set_crs("EPSG:4326")
    else:
        gdf = gdf.to_crs("EPSG:4326")

    # Filtra pelo Cerrado (bounding box aproximado)
    if filter_cerrado:
        cerrado_geom = box(*CERRADO_BBOX)
        mask = gdf.geometry.intersects(cerrado_geom)
        n_before = len(gdf)
        gdf = gdf[mask].copy()
        console.print(
            f"[cyan]Filtro Cerrado:[/cyan] {n_before} → {len(gdf)} TIs "
            f"(bbox {CERRADO_BBOX})"
        )

    if gdf.empty:
        raise ValueError(
            "Nenhuma TI encontrada após o filtro do Cerrado. "
            "Verifique CERRADO_BBOX ou defina filter_cerrado=False."
        )

    gdf.to_file(gpkg_out, driver="GPKG")
    console.print(f"[green]✓ Salvo em GPKG:[/green] {gpkg_out}")

    # Remove GeoJSON intermediário para economizar espaço
    if geojson_out.exists():
        geojson_out.unlink()

    return gpkg_out

