# Teste de paralelismo pré-tratamento
def test_parallel_trends(df_es: pd.DataFrame) -> dict:
    """Testa se coeficientes pré-2013 são conjuntamente zero (F-test)."""
    pre_coefs = df_es[df_es["year"] < 2012]["coef"].values
    pre_ses   = df_es[df_es["year"] < 2012]["se"].values
    if len(pre_coefs) == 0:
        return {"F": np.nan, "p": np.nan, "n": 0}
    # Teste t conjunto aproximado: média / SE médio
    t_stat = np.mean(pre_coefs) / (np.std(pre_coefs) / np.sqrt(len(pre_coefs)))
    p_val  = 2 * (1 - stats.t.cdf(abs(t_stat), df=len(pre_coefs)-1))
    return {"t": round(t_stat, 3), "p": round(p_val, 3), "n": len(pre_coefs)}

