# 1. PARÂMETROS
# ============================================================

MODIS_TERRA      = "MODIS/061/MOD14A1"
MODIS_AQUA       = "MODIS/061/MYD14A1"
FIRE_MASK_BAND   = "FireMask"
FIRE_THRESHOLD   = 7        # ≥ 7 = fogo confirmado
FIRE_SCALE       = 1000     # 1km
EE_TILE_SCALE    = 4

TASK_PREFIX_HS   = "hotspots_annual"
EE_EXPORT_FOLDER = f"{PROJECT_NAME}/07_exports/fire_hotspots"
MONITOR_INTERVAL = 30
MONITOR_TIMEOUT  = 7200

