# 6. CONSOLIDA TUDO
# ============================================================

def consolidate(csv_paths: list) -> pd.DataFrame:
    dfs = []
    for p in sorted(csv_paths):
        df_tmp = pd.read_csv(p)
        console.print(f"  [dim]{Path(p).name}: {len(df_tmp):,} linhas[/dim]")
        dfs.append(df_tmp)

    df = pd.concat(dfs, ignore_index=True)

    if "mean" in df.columns and "precip_mm" not in df.columns:
        df = df.rename(columns={"mean": "precip_mm"})

    drop = [c for c in df.columns if c.startswith("system:") or c in (".geo", "geo")]
    df   = df.drop(columns=drop, errors="ignore")

    df["year"]      = pd.to_numeric(df["year"],      errors="coerce").astype("Int64")
    df["month"]     = pd.to_numeric(df["month"],     errors="coerce").astype("Int64")
    df["ti_id"]     = pd.to_numeric(df["ti_id"],     errors="coerce").astype("Int64")
    df["precip_mm"] = pd.to_numeric(df["precip_mm"], errors="coerce").fillna(0)

    df = add_time_fields(df)
    df = df[df["period"] != "outside"].copy()
    df = df.sort_values(["ti_id", "year", "month"]).reset_index(drop=True)
    return df

# ============================================================
# 7. PIPELINE PRINCIPAL
# ============================================================

def run_chirps_pipeline() -> pd.DataFrame:

    # ── Etapa 1: FeatureCollection ────────────────────────────────────────
    console.print("\n[bold cyan]— Etapa 1/4: FeatureCollection —[/bold cyan]")
    tis_fc = build_tis_fc()

    # ── Etapa 2: Determina quais anos precisam ser processados ────────────
    console.print("\n[bold cyan]— Etapa 2/4: Verificando anos necessários —[/bold cyan]")
    all_years    = list(range(START_YEAR, END_YEAR + 1))
    years_done   = [y for y in all_years
                    if (EXPORT_LOCAL_DIR / f"{TASK_PREFIX}_{y}.csv").exists()]
    years_needed = [y for y in all_years if y not in years_done]

    console.print(f"  Anos com CSV local:  {len(years_done)}")
    console.print(f"  Anos a processar:    {len(years_needed)} {years_needed}")

    # ── Etapa 3: Export Tasks para anos faltantes ─────────────────────────
    if years_needed:
        console.print("\n[bold cyan]— Etapa 3/4: Export Tasks —[/bold cyan]")
        tasks = launch_tasks(tis_fc, years=years_needed)

        if tasks:
            monitor_tasks(tasks)

        # Baixa CSVs via Drive API
        console.print("\n[bold cyan]— Etapa 4/4: Download via Drive API —[/bold cyan]")
        download_csvs_from_drive(years_needed)
    else:
        console.print("[green]✓ Todos os anos já têm CSV local.[/green]")

    # ── Etapa 5: Consolida todos os CSVs disponíveis ──────────────────────
    console.print("\n[bold cyan]— Consolidando —[/bold cyan]")
    csv_paths = sorted(EXPORT_LOCAL_DIR.glob(f"{TASK_PREFIX}_*.csv"))

    if not csv_paths:
        raise RuntimeError(
            "Nenhum CSV disponível após todas as tentativas.\n"
            "Verifique: https://code.earthengine.google.com/tasks"
        )

    df = consolidate(csv_paths)
    console.print(f"[green]✓ {len(df):,} registros consolidados.[/green]")
    return df


