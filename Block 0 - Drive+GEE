def save_json(obj, path):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(obj, f, indent=2, ensure_ascii=False)

def read_table(path):
    path = Path(path)
    if path.suffix == ".parquet":
        return pd.read_parquet(path)
    if path.suffix == ".csv":
        return pd.read_csv(path)
    raise ValueError(f"Formato não suportado: {path}")

def write_table(df, path):
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.suffix == ".parquet":
        df.to_parquet(path, index=False)
    elif path.suffix == ".csv":
        df.to_csv(path, index=False)
    else:
        raise ValueError(f"Formato não suportado: {path}")

def checkpoint_load_or_run(name, func, ext="parquet", force=FORCE_REPROCESS):
    path = cache_path(name, ext)
    if path.exists() and not force:
        console.print(f"[cyan]✓ Carregando checkpoint:[/cyan] {path.name}")
        return read_table(path)
    console.print(f"[yellow]→ Processando:[/yellow] {name}")
    df = func()
    write_table(df, path)
    console.print(f"[green]✓ Checkpoint salvo:[/green] {path}")
    return df

