def get_estimates_burned_area():
    ests = []

    ba_dep = find_depvar(ba_results, ["log_burned_dry", "log_burned", "log_burned_ha", "log BA", "burned"])
    did_dep = find_depvar(did_results, ["log_burned_dry", "log_burned", "log_burned_ha", "log BA", "burned"])
    trend_dep = find_depvar(trend_df, ["log_burned_dry", "log_burned", "log_burned_ha", "log BA", "burned"])

    console.print(f"Detected burned-area dep_var: BA={ba_dep} | DiD={did_dep} | Trend={trend_dep}")

    if ba_dep is not None and {"dep_var", "variable", "coef", "ci_low", "ci_high", "pvalue"}.issubset(ba_results.columns):
        r = ba_results[
            (ba_results["dep_var"].astype(str) == ba_dep) &
            (ba_results["variable"].astype(str).str.contains("post_x_dry|post:dry|post_dry", case=False, regex=True, na=False))
        ]
        if not r.empty:
            r = r.iloc[0]
            ests.append({"label": "Before-after", "coef": r["coef"], "ci_low": r["ci_low"],
                         "ci_high": r["ci_high"], "pvalue": r["pvalue"], "color": C_PRE})

    if did_dep is not None and {"dep_var", "variable", "coef", "ci_low", "ci_high", "pvalue"}.issubset(did_results.columns):
        r = did_results[
            (did_results["dep_var"].astype(str) == did_dep) &
            (did_results["variable"].astype(str).str.contains("post_x_dry_x_treat|post.*dry.*treat", case=False, regex=True, na=False))
        ]
        if not r.empty:
            r = r.iloc[0]
            ests.append({"label": "DiD", "coef": r["coef"], "ci_low": r["ci_low"],
                         "ci_high": r["ci_high"], "pvalue": r["pvalue"], "color": C_POST})

    if trend_dep is not None and {"dep_var", "season", "coef_trend", "se_trend", "pval_trend"}.issubset(trend_df.columns):
        r = trend_df[
            (trend_df["dep_var"].astype(str) == trend_dep) &
            (trend_df["season"].astype(str).isin(["Seca", "dry"]))
        ]
        if not r.empty:
            r = r.iloc[0]
            coef5 = r["coef_trend"] * 5
            se5 = r["se_trend"] * 5
            ests.append({"label": "Post trend\n×5 years", "coef": coef5,
                         "ci_low": coef5 - 1.96 * se5,
                         "ci_high": coef5 + 1.96 * se5,
                         "pvalue": r["pval_trend"], "color": C_BRIF})

    return pd.DataFrame(ests)

def plot_forest(ax, est_df, title, xlabel="Estimated change (%)"):
    ax.axvline(0, color="black", linewidth=0.8, linestyle=":")

    if est_df.empty:
        ax.text(0.5, 0.5, "No estimates available", transform=ax.transAxes,
                ha="center", va="center")
        ax.set_title(title, fontweight="bold")
        return

    df = est_df.copy()
    df["pct"] = df["coef"].apply(pct_from_logcoef)
    df["pct_low"] = df["ci_low"].apply(pct_from_logcoef)
    df["pct_high"] = df["ci_high"].apply(pct_from_logcoef)

    y = np.arange(len(df))[::-1]
    finite_vals = pd.concat([df["pct_low"], df["pct_high"]]).replace([np.inf, -np.inf], np.nan).dropna()
    if len(finite_vals) > 0:
        ax.set_xlim(finite_vals.min() - 10, finite_vals.max() + 15)

    for yi, (_, row) in zip(y, df.iterrows()):
        ax.errorbar(
            row["pct"], yi,
            xerr=[[row["pct"] - row["pct_low"]], [row["pct_high"] - row["pct"]]],
            fmt="o", color=row["color"], ecolor=row["color"],
            elinewidth=2, capsize=4, markersize=7,
        )
        if not pd.isna(row["pvalue"]):
            sig = "***" if row["pvalue"] < 0.001 else "**" if row["pvalue"] < 0.01 else "*" if row["pvalue"] < 0.05 else "n.s."
            ax.text(row["pct_high"] + 2, yi, sig, va="center", fontsize=8)

    ax.set_yticks(y)
    ax.set_yticklabels(df["label"])
    ax.set_xlabel(xlabel)
    ax.set_title(title, fontweight="bold")
    ax.grid(axis="x", alpha=0.2)
    ax.grid(axis="y", alpha=0)

def climate_estimates(dep_var_candidates):
    if clim_df.empty:
        return pd.DataFrame()

    df = clim_df.copy()

    if "dep_var" in df.columns:
        dep = find_depvar(df, dep_var_candidates)
        if dep is not None:
            df = df[df["dep_var"].astype(str) == dep]

    if "variable" in df.columns:
        df = df[df["variable"].astype(str).str.contains("post_x_dry|post:dry|post_dry", case=False, regex=True, na=False)]

    if df.empty or "coef" not in df.columns:
        return pd.DataFrame()

    if "ci_low" not in df.columns or "ci_high" not in df.columns:
        if "se" in df.columns:
            df["ci_low"] = df["coef"] - 1.96 * df["se"]
            df["ci_high"] = df["coef"] + 1.96 * df["se"]
        else:
            df["ci_low"] = np.nan
            df["ci_high"] = np.nan

    if "pvalue" not in df.columns:
        df["pvalue"] = np.nan

    model_col = None
    for c in ["spec", "model_spec", "model", "climate_spec"]:
        if c in df.columns:
            model_col = c
            break

    df["model_label"] = df[model_col].astype(str) if model_col else [f"Model {i+1}" for i in range(len(df))]
    return df[["model_label", "coef", "ci_low", "ci_high", "pvalue"]].copy()

def plot_climate_forest(ax, df, title):
    ax.axvline(0, color="black", linewidth=0.8, linestyle=":")

    if df.empty:
        ax.text(0.5, 0.5, "Climate robustness\nnot available",
                transform=ax.transAxes, ha="center", va="center")
        ax.set_title(title, fontweight="bold")
        return

    d = df.copy()
    d["pct"] = d["coef"].apply(pct_from_logcoef)
    d["pct_low"] = d["ci_low"].apply(pct_from_logcoef)
    d["pct_high"] = d["ci_high"].apply(pct_from_logcoef)

    y = np.arange(len(d))[::-1]
    colors = plt.cm.tab20(np.linspace(0, 1, len(d)))

    for i, (yi, (_, row)) in enumerate(zip(y, d.iterrows())):
        ax.errorbar(
            row["pct"], yi,
            xerr=[[row["pct"] - row["pct_low"]], [row["pct_high"] - row["pct"]]],
            fmt="o", color=colors[i], ecolor=colors[i],
            elinewidth=2, capsize=4, markersize=6,
        )

    ax.set_yticks(y)
    ax.set_yticklabels(d["model_label"])
    ax.set_xlabel("Estimated change (%)")
    ax.set_title(title, fontweight="bold")
    ax.grid(axis="x", alpha=0.2)
    ax.grid(axis="y", alpha=0)

