def filter_tis_by_biome(tis: gpd.GeoDataFrame) -> gpd.GeoDataFrame:
    """
    Filtra as TIs que intersectam o limite do bioma Cerrado.
    Usa o arquivo biome_border.shp em 00_raw/.
    """
    biome_path = DIRS["raw"] / "biome_border.shp"

    if not biome_path.exists():
        console.print("[yellow]⚠ biome_border.shp não encontrado — usando todas as TIs.[/yellow]")
        return tis

    console.print(f"[yellow]→ Carregando limite do Cerrado: {biome_path.name}[/yellow]")
    cerrado = gpd.read_file(biome_path)

    # Garante mesmo CRS
    cerrado = cerrado.to_crs("EPSG:4326")

    # Dissolve em uma geometria única
    cerrado_union = cerrado.dissolve()

    # Filtra TIs que intersectam o Cerrado
    n_before = len(tis)
    tis_cerrado = tis[tis.geometry.intersects(cerrado_union.geometry.iloc[0])].copy()
    n_after = len(tis_cerrado)

    console.print(
        f"[green]✓ TIs filtradas pelo Cerrado:[/green] "
        f"{n_before} → {n_after} TIs "
        f"({n_before - n_after} removidas)"
    )

    # Salva fronteira do Cerrado para uso posterior
    cerrado_union.to_file(DIRS["boundaries"] / "cerrado_border.gpkg", driver="GPKG")

    return tis_cerrado.reset_index(drop=True)


