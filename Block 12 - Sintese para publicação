              color=C_POST, edgecolor="white", label="Post-BRIF")

    ax_e.axvline(pre_vals.mean(), color=C_PRE, linewidth=2, linestyle="--")
    ax_e.axvline(post_vals.mean(), color=C_POST, linewidth=2, linestyle="--")
