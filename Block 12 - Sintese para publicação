def launch_frp_tasks():
    """Exporta FRP médio mensal por TI (MODIS Terra + Aqua)."""
    tis_fc    = ee.FeatureCollection(EE_ASSET_TIS)
    terra_frp = ee.ImageCollection("MODIS/061/MOD14A1")
    aqua_frp  = ee.ImageCollection("MODIS/061/MYD14A1")
    tasks     = {}

    all_years    = list(range(START_YEAR, END_YEAR + 1))
    years_needed = [y for y in all_years
                    if not (EXPORT_LOCAL_FRP / f"{TASK_PREFIX_FRP}_{y}.csv").exists()]

    console.print(f"  Anos a processar: {len(years_needed)}")

    for year in years_needed:
        month_fcs = []
        for month in range(1, 13):
            start = ee.Date.fromYMD(year, month, 1)
            end   = start.advance(1, "month")

            # FRP: constrói imagem mensal de FRP médio (Terra + Aqua)
            # Passo 1: filtra e mascara pixels confirmados de cada coleção
            terra_month = terra_frp.filterDate(start, end)
            aqua_month  = aqua_frp.filterDate(start, end)

            # Passo 2: para cada imagem diária, mascara FireMask < 7 e escala
            def mask_frp(img):
                fire_mask = img.select("FireMask").gte(7)
                frp       = img.select("MaxFRP").multiply(0.1).updateMask(fire_mask)
                return frp.rename("frp_mw")

            terra_frp_m = terra_month.map(mask_frp)
            aqua_frp_m  = aqua_month.map(mask_frp)

            # Passo 3: combina Terra + Aqua e calcula média e máximo mensal
            combined_ic  = terra_frp_m.merge(aqua_frp_m)
            n_images     = combined_ic.size()

            # Se não há imagens no mês, retorna zeros
            frp_mean_img = combined_ic.mean().rename("frp_mean")
            frp_max_img  = combined_ic.max().rename("frp_max")
            frp_img      = frp_mean_img.addBands(frp_max_img)

            # Passo 4: reduz por TI — média do FRP sobre pixels de fogo
            reduced = frp_img.reduceRegions(
                collection = tis_fc,
                reducer    = ee.Reducer.mean().setOutputs(["frp_mean","frp_max"]),
                scale      = 1000,
                tileScale  = 4,
            ).map(lambda f: f
                .set("year",  year)
                .set("month", month)
                .select(["terrai_cod","year","month","frp_mean","frp_max"],
                        None, False)
            )
            month_fcs.append(reduced)

        task = ee.batch.Export.table.toDrive(
            collection     = ee.FeatureCollection(month_fcs).flatten(),
            description    = f"{TASK_PREFIX_FRP}_{year}",
            folder         = EE_EXPORT_FRP,
            fileNamePrefix = f"{TASK_PREFIX_FRP}_{year}",
            fileFormat     = "CSV",
        )
        task.start()
        tasks[year] = task
        console.print(f"  [yellow]→ Task FRP: {year}[/yellow]")
        time.sleep(0.3)

    return tasks, years_needed

def monitor_frp(tasks):
    if not tasks:
        return
    console.print(f"  Monitorando {len(tasks)} tasks FRP...")
    t0 = time.time()
    pending = set(tasks.keys())
    while pending and (time.time()-t0) < 7200:
        all_t = ee.data.getTaskList()
        for t in all_t:
            desc  = t.get("description","")
            state = t.get("state","")
            if not desc.startswith(TASK_PREFIX_FRP):
                continue
            try:
                yr = int(desc.replace(f"{TASK_PREFIX_FRP}_",""))
            except:
                continue
            if yr not in pending:
                continue
            if state == "COMPLETED":
                pending.discard(yr)
                console.print(f"  [green]✓ FRP {yr}[/green]")
            elif state in ("FAILED","CANCELLED"):
                pending.discard(yr)
                console.print(f"  [red]✗ FRP {yr}: {state}[/red]")
        if not pending:
            break
        console.print(f"  {len(tasks)-len(pending)}/{len(tasks)} | {30}s...")
        time.sleep(30)

def download_frp_csvs(years):
    auth.authenticate_user()
    svc = build("drive","v3",cache_discovery=False)
    downloaded = {}
    for year in years:
        fname = f"{TASK_PREFIX_FRP}_{year}.csv"
        dest  = EXPORT_LOCAL_FRP / fname
        if dest.exists():
            downloaded[year] = dest
            continue
        res = svc.files().list(
            q=f"name='{fname}' and mimeType='text/csv' and trashed=false",
            spaces="drive", fields="files(id,name)"
        ).execute()
        files = res.get("files",[])
        if not files:
            continue
        req = svc.files().get_media(fileId=files[0]["id"])
        buf = io.BytesIO()
        dl  = MediaIoBaseDownload(buf,req)
        done = False
        while not done:
            _,done = dl.next_chunk()
        dest.write_bytes(buf.getvalue())
        downloaded[year] = dest
        console.print(f"  [green]✓ FRP {fname}[/green]")
    return downloaded

