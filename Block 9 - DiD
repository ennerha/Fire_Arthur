console.print("\n[yellow]в†’ Event Study com grupo controle...[/yellow]")

def run_did_event_study(dep_var, label):
    df = panel[panel["year_int"] != 2013].copy()
    years = sorted(df["year_int"].unique())
    years_no_base = [y for y in years if y != 2012]

    for y in years_no_base:
        df[f"d_{y}_treat"] = ((df["year_int"] == y) & (df["treated"] == 1)).astype(int)
        df[f"d_{y}_ctrl"]  = ((df["year_int"] == y) & (df["treated"] == 0)).astype(int)

    treat_terms = " + ".join([f"d_{y}_treat" for y in years_no_base])
    ctrl_terms  = " + ".join([f"d_{y}_ctrl"  for y in years_no_base])
    formula = f"{dep_var} ~ {treat_terms} + {ctrl_terms} + C(ti_id_str) - 1"

    try:
        m = smf.ols(formula, data=df).fit(
            cov_type="cluster",
            cov_kwds={"groups": df["ti_id_str"]}
        )

        rows = []
        for y in years:
            for grupo, suffix in [("Tratada", "treat"), ("Controle", "ctrl")]:
                if y == 2012:
                    rows.append({"year": y, "grupo": grupo, "coef": 0.0,
                                 "ci_low": 0.0, "ci_high": 0.0, "pvalue": 1.0})
                    continue
                var = f"d_{y}_{suffix}"
                if var in m.params:
                    ci = m.conf_int().loc[var]
                    rows.append({
                        "year":    y,
                        "grupo":   grupo,
                        "coef":    m.params[var],
                        "ci_low":  ci[0],
                        "ci_high": ci[1],
                        "pvalue":  m.pvalues[var],
                    })

        return pd.DataFrame(rows)
    except Exception as e:
        console.print(f"  [red]вњ— Event Study DiD {label}: {e}[/red]")
        return pd.DataFrame()

