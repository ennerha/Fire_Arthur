def run_event_study(dep_var: str, label: str) -> pd.DataFrame:
    """
    Estima efeito ano a ano relativo a 2012 (ano base pré-BRIF).
    Modelo: Y_it = Σ_t β_t · I(year=t) + αi + γt + ε_it
    Ano base: 2012 (omitido → coeficiente = 0)
    """
    df = panel_annual[panel_annual["year"] != 2013].copy()  # exclui transição
    df["year_str"] = "y" + df["year"].astype(str)

    # Ano base: 2012
    years = sorted(df["year"].unique())
    years_no_base = [y for y in years if y != 2012]

    # Cria dummies de ano × (ano ≠ base)
    for y in years_no_base:
        df[f"d_{y}"] = (df["year"] == y).astype(int)

    dummy_terms = " + ".join([f"d_{y}" for y in years_no_base])
    formula = f"{dep_var} ~ {dummy_terms} + C(ti_id_str) - 1"

    try:
        model = smf.ols(formula, data=df).fit(
            cov_type="cluster",
            cov_kwds={"groups": df["ti_id_str"]}
        )

        rows = []
        for y in years:
            if y == 2012:
                rows.append({"year": y, "coef": 0.0, "ci_low": 0.0,
                             "ci_high": 0.0, "pvalue": 1.0, "se": 0.0})
                continue
            var = f"d_{y}"
            if var in model.params:
                ci = model.conf_int().loc[var]
                rows.append({
                    "year":    y,
                    "coef":    model.params[var],
                    "se":      model.bse[var],
                    "ci_low":  ci[0],
                    "ci_high": ci[1],
                    "pvalue":  model.pvalues[var],
                })

        df_res = pd.DataFrame(rows).sort_values("year")
        df_res["sig"]   = df_res["pvalue"].apply(
            lambda p: "***" if p<0.001 else "**" if p<0.01 else "*" if p<0.05 else ""
        )
        df_res["dep_var"] = dep_var
        df_res["label"]   = label

        console.print(f"  [green]✓ Event study: {label}[/green]")
        return df_res

    except Exception as e:
        console.print(f"  [red]✗ {label}: {e}[/red]")
        return pd.DataFrame()


