    ("log_burned_ha",  "Log Área Queimada"),
    ("log_fire_count", "Log Focos de Calor"),
]:
    for season, season_label in [("dry", "Seca"), ("wet", "Chuvosa")]:
        df_s = panel_pos[panel_pos["season"] == season].copy()

        # Modelo linear
        try:
            m_lin = smf.ols(
                f"{dep_var} ~ years_since + precip_mm + C(month) + C(ti_id_str) - 1",
                data=df_s
            ).fit(cov_type="cluster", cov_kwds={"groups": df_s["ti_id_str"]})

