# SPI-3: média de precipitação dos últimos 3 meses, padronizada por mês
# Agrega precipitação média do Cerrado por mês (todas as TIs)
precip_cerrado = (
    panel.groupby(["year_int","month_int"])["precip_mm"]
    .mean()
    .reset_index()
    .rename(columns={"year_int":"year","month_int":"month"})
    .sort_values(["year","month"])
)

# SPI-3: janela de 3 meses
precip_cerrado["precip_3m"] = precip_cerrado["precip_mm"].rolling(3, min_periods=2).mean()

# Padroniza por mês do ano (remove sazonalidade)
for m in range(1, 13):
    mask = precip_cerrado["month"] == m
    mu  = precip_cerrado.loc[mask, "precip_3m"].mean()
    std = precip_cerrado.loc[mask, "precip_3m"].std()
    if std > 0:
        precip_cerrado.loc[mask, "spi3"] = (precip_cerrado.loc[mask, "precip_3m"] - mu) / std
    else:
        precip_cerrado.loc[mask, "spi3"] = 0

