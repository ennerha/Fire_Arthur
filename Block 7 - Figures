# — ax3 e ax4: coeficientes —
for ax, dep_var, title in [
    (ax3, "log_burned_ha",  "(C) Log Área Queimada"),
    (ax4, "log_fire_count", "(D) Log Focos de Calor"),
]:
    df_p = df_coef[df_coef["dep_var"] == dep_var].sort_values("coef")
    colors_bar = [
