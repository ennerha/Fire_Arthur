def classify_enso(oni):
    if pd.isna(oni):
        return "Neutro"
    if oni >= 1.5:
        return "El Niño Forte"
    elif oni >= 0.5:
        return "El Niño"
    elif oni <= -1.5:
        return "La Niña Forte"
    elif oni <= -0.5:
        return "La Niña"
    else:
        return "Neutro"

