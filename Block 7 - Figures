    ("precip_dry",     "precip_wet",     "Precipitação média (mm)",        False),
]

for ax, (var_dry, var_wet, ylabel, show_legend) in zip(axes, panels_config):
    ax.plot(ts_year["year"], ts_year[var_dry],
            color=C_DRY,  linewidth=2, marker="o", markersize=4,
