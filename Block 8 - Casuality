                "dep_var":    dep_var,
                "dep_label":  dep_label,
                "season":     season_label,
                "model":      "Linear",
                "coef_trend": m_lin.params.get("years_since", np.nan),
                "se_trend":   m_lin.bse.get("years_since", np.nan),
                "pval_trend": m_lin.pvalues.get("years_since", np.nan),
                "r2":         m_lin.rsquared,
            })
        except Exception as e:
            console.print(f"  [red]✗ Linear {dep_label} {season_label}: {e}[/red]")

        # Modelo quadrático
        try:
            m_quad = smf.ols(
                f"{dep_var} ~ years_since + years_since2 + precip_mm + "
                f"C(month) + C(ti_id_str) - 1",
                data=df_s
            ).fit(cov_type="cluster", cov_kwds={"groups": df_s["ti_id_str"]})

