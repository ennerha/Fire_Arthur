def index_to_pre(df, year_col, value_col, pre_start=2003, pre_end=2012):
    out = df.copy()
    pre = out[(out[year_col] >= pre_start) & (out[year_col] <= pre_end)][value_col].mean()
    if pd.isna(pre) or pre == 0:
        out[value_col + "_index"] = np.nan
    else:
        out[value_col + "_index"] = 100 * out[value_col] / pre
    return out

def find_depvar(df, candidates):
    if df.empty or "dep_var" not in df.columns:
        return None
    depvars = df["dep_var"].astype(str).unique().tolist()
    for cand in candidates:
        for d in depvars:
            if cand.lower() in d.lower():
                return d
    return None

