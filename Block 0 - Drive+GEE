def gdf_to_ee_fc(gdf):
    features = []
    for _, row in tqdm(gdf.iterrows(), total=len(gdf), desc="Convertendo TIs para EE"):
        geom_json = json.loads(
            gpd.GeoSeries([row.geometry], crs="EPSG:4326").to_json()
        )["features"][0]["geometry"]

        feat = ee.Feature(
            ee.Geometry(geom_json),
            {
                "ti_id":    int(row["ti_id"]),
                "ti_name":  str(row["ti_name"]),
                "area_ha":  float(row["area_ha"]),
                "area_km2": float(row["area_km2"]),
            }
        )
        features.append(feat)
    return ee.FeatureCollection(features)

