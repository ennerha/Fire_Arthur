# 2. MÉTRICAS ANUAIS POR TI
# ============================================================

def compute_annual_metrics(panel: pd.DataFrame) -> pd.DataFrame:
    rows = []

    for (ti_id, year), grp in panel.groupby(["ti_id", "year"]):
        dry = grp[grp["dry"] == 1]
        wet = grp[grp["dry"] == 0]

        area_ha = grp["area_ha"].iloc[0]

        # ── Área queimada ──────────────────────────────────────
        burned_total = grp["burned_ha"].sum()
        burned_dry   = dry["burned_ha"].sum()
        burned_wet   = wet["burned_ha"].sum()

        # ── Focos ──────────────────────────────────────────────
        fire_total = grp["fire_count"].sum()
        fire_dry   = dry["fire_count"].sum()
        fire_wet   = wet["fire_count"].sum()

        # ── Precipitação ───────────────────────────────────────
        precip_total = grp["precip_mm"].sum()
        precip_dry   = dry["precip_mm"].sum()
        precip_wet   = wet["precip_mm"].sum()

        # ── Redistribuição sazonal ─────────────────────────────
        burned_dry_frac = burned_dry / burned_total if burned_total > 0 else np.nan
        fire_dry_frac   = fire_dry   / fire_total   if fire_total   > 0 else np.nan

        # ── Recorrência (reburning) ────────────────────────────
        # Número de meses com fogo no ano (proxy de recorrência intra-anual)
        months_with_fire   = (grp["burned_ha"] > 0).sum()
        months_with_fire_dry = (dry["burned_ha"] > 0).sum()

        # ── Fragmentação ───────────────────────────────────────
        # Proxy: variância mensal da área queimada na seca
        # Alta variância → fogo concentrado em poucos meses (menos fragmentado)
        # Baixa variância → fogo distribuído (mais fragmentado/manejado)
        dry_burned_vals = dry["burned_ha"].values
        fragmentation_cv = (np.std(dry_burned_vals) / np.mean(dry_burned_vals)
                            if np.mean(dry_burned_vals) > 0 else np.nan)

        rows.append({
            "ti_id":   ti_id,
            "ti_name": grp["ti_name"].iloc[0],
            "year":    year,
            "period":  grp["period"].iloc[0],
            "area_ha": area_ha,

            # Área queimada
            "burned_ha_total":    burned_total,
            "burned_ha_dry":      burned_dry,
            "burned_ha_wet":      burned_wet,
            "burned_pct_total":   (burned_total / area_ha * 100) if area_ha > 0 else np.nan,
            "burned_dry_frac":    burned_dry_frac,

            # Focos
            "fire_total":         fire_total,
            "fire_dry":           fire_dry,
            "fire_wet":           fire_wet,
            "fire_dry_frac":      fire_dry_frac,
            "fire_density_mean":  grp["fire_density"].mean(),

            # Sazonalidade
            "months_with_fire":      months_with_fire,
            "months_with_fire_dry":  months_with_fire_dry,
            "fragmentation_cv":      fragmentation_cv,   # coef variação mensal

            # Precipitação
            "precip_total_mm":    precip_total,
            "precip_dry_mm":      precip_dry,
            "precip_wet_mm":      precip_wet,
            "precip_anomaly_mean":grp["precip_anomaly"].mean(),
        })

    df = pd.DataFrame(rows)
    df["year"] = df["year"].astype("Int64")
    return df.sort_values(["ti_id", "year"]).reset_index(drop=True)


