        console.print(f"  [cyan]✓ {fig_file} já existe — pulando.[/cyan]")
        plt.close(fig)
        if prog and task is not None:
            prog.advance(task)
            if next_desc:
                prog.update(task, description=next_desc)
        return
    fig.savefig(p, dpi=DPI, bbox_inches="tight")
    plt.close(fig)
    console.print(f"[green]✓ {fig_file} salva ({p.stat().st_size/1024:.0f} KB)[/green]")
    if prog and task is not None:
        prog.advance(task)
