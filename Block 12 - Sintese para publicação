def export_fire_patches():
    """
    Exporta tamanho médio de evento de fogo (patch size) por TI×ano.
    Usa MapBiomas Fire — conecta pixels queimados em polígonos e calcula área.
    """
    years_needed = [y for y in range(2003, 2024)
                    if not (EXPORT_LOCAL_PATCH / f"{TASK_PREFIX_PATCH}_{y}.csv").exists()]

    if not years_needed:
        console.print("  [cyan]✓ Fire patches: all years already exported[/cyan]")
        return {}, []

    console.print(f"  Years to process: {len(years_needed)}")
    tis_fc    = ee.FeatureCollection(EE_ASSET_TIS)
    mapbiomas = ee.Image(
        "projects/mapbiomas-public/assets/brazil/fire/collection3/"
        "mapbiomas_fire_collection3_monthly_burned_coverage_v1"
    )

    tasks = {}
    for year in years_needed:
        band = f"burned_coverage_{year}"

        # Cria imagem binária: queimado em qualquer mês do ano
        burned_binary = (
            mapbiomas.select(band)
            .divide(100).floor().toInt()
            .gte(1)  # qualquer mês = queimado
            .selfMask()
            .rename("burned")
        )

        # Conecta pixels vizinhos em patches e calcula área de cada patch por TI
        # Usa connectedPixelCount como proxy de tamanho de patch
        patch_size = burned_binary.connectedPixelCount(maxSize=1024).rename("patch_pixels")
        patch_area = patch_size.multiply(0.09)  # ha

        reduced = patch_area.reduceRegions(
            collection = tis_fc,
            reducer    = ee.Reducer.mean().combine(
                ee.Reducer.max(), sharedInputs=True
            ).setOutputs(["mean_patch_ha","max_patch_ha"]),
            scale      = 30,
            tileScale  = 4,
        ).map(lambda f: f
            .set("year", year)
            .select(["terrai_cod","year","mean_patch_ha","max_patch_ha"], None, False)
        )

        task = ee.batch.Export.table.toDrive(
            collection     = reduced,
            description    = f"{TASK_PREFIX_PATCH}_{year}",
            folder         = f"{PROJECT_NAME}/07_exports/fire_patches",
            fileNamePrefix = f"{TASK_PREFIX_PATCH}_{year}",
            fileFormat     = "CSV",
        )
        task.start()
        tasks[year] = task
        console.print(f"  [yellow]→ Task patches: {year}[/yellow]")
        time.sleep(0.3)

    return tasks, years_needed

