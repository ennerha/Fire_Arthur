    ax_trend1.plot(xr, np.poly1d(z1)(xr), color=C_DRY, linewidth=1.5,
                   linestyle=":", alpha=0.8,
                   label=f"Trend: {z1[0]:+.0f} ha/yr (p={p1:.3f})")
    ax_t1_twin.plot(xr, np.poly1d(z2)(xr), color="#BF360C", linewidth=1.5,
                    linestyle=":", alpha=0.8,
                    label=f"Trend: {z2[0]:+.2f}/yr (p={p2:.4f})")

ax_trend1.set_title("(D) Post-BRIF Temporal Trend (2014–2023) — Dry Season\n"
                    "Declining hotspots with increasing burned area = progressive reorganization",
                    fontsize=10, fontweight="bold")
ax_trend1.set_xlabel("Year", fontsize=9)
ax_trend1.set_ylabel("Burned area (ha/TI/month)", fontsize=9, color=C_DRY)
ax_t1_twin.set_ylabel("Hotspots/TI/month", fontsize=9, color="#BF360C")
ax_trend1.legend(fontsize=8, loc="upper left")
ax_t1_twin.legend(fontsize=8, loc="upper right")
ax_trend1.grid(alpha=0.2)
ax_trend1.xaxis.set_major_locator(mticker.MultipleLocator(1))

# ax_proj: Projeção do aprendizado institucional
years_proj = np.arange(2014, 2035)
slope_fire  = -0.032  # -3.2%/ano (log escala)
slope_area  = -0.022  # -2.2%/ano

# Base: média 2014
base_fire = ts_pos_dry["fire_count_mean"].iloc[0] if len(ts_pos_dry)>0 else 50
base_area = ts_pos_dry["burned_ha_mean"].iloc[0]  if len(ts_pos_dry)>0 else 1500

proj_fire = base_fire * np.exp(slope_fire * (years_proj - 2014))
proj_area = base_area * np.exp(slope_area * (years_proj - 2014))

ax_proj.plot(years_proj, proj_fire/base_fire*100,
             color="#BF360C", linewidth=2.2, linestyle="--", label="Hotspots (% of 2014)")
ax_proj.plot(years_proj, proj_area/base_area*100,
             color=C_DRY, linewidth=2.2, linestyle="-", label="Burned area (% of 2014)")
ax_proj.axhline(100, color="gray", linewidth=0.8, linestyle=":", alpha=0.5)
ax_proj.axhline(50, color="red", linewidth=0.8, linestyle=":", alpha=0.3)
ax_proj.axvline(2024, color="gray", linewidth=1, linestyle="--", alpha=0.5,
                label="Last observation")
ax_proj.fill_between(years_proj[years_proj>=2024],
                     proj_fire[years_proj>=2024]/base_fire*100,
                     100, alpha=0.08, color="#BF360C")
ax_proj.set_title("(E) Institutional Learning Projection\n"
                  "If trend continues at observed slope (−3.2%/yr hotspots)",
                  fontsize=10, fontweight="bold")
ax_proj.set_xlabel("Year", fontsize=9)
ax_proj.set_ylabel("% of 2014 baseline", fontsize=9)
ax_proj.legend(fontsize=8)
ax_proj.grid(alpha=0.2)
ax_proj.text(0.6, 0.15,
             "50% reduction\nin hotspots\nby ~2036",
             transform=ax_proj.transAxes, fontsize=8.5,
             bbox=dict(boxstyle="round",facecolor="lightyellow",alpha=0.9))
ax_proj.xaxis.set_major_locator(mticker.MultipleLocator(3))

