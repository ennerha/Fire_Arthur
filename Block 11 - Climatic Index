clim_results = []

def run_climate_model(dep_var, dep_label, controls, model_name):
    control_str = " + ".join(controls)
    formula = (f"{dep_var} ~ post + dry + post_x_dry + precip_mm + "
               f"{control_str} + C(month_int) + C(ti_id_str) - 1")
    try:
        m = smf.ols(formula, data=panel_model_clim).fit(
            cov_type="cluster",
            cov_kwds={"groups": panel_model_clim["ti_id_str"]}
        )
        for var in ["post_x_dry", "oni", "oni_x_dry", "spi3", "pdo", "amo"]:
            if var in m.params:
                ci = m.conf_int().loc[var]
                clim_results.append({
                    "model":    model_name,
                    "dep_var":  dep_var,
                    "dep_label":dep_label,
                    "variable": var,
                    "coef":     m.params[var],
                    "se":       m.bse[var],
                    "pvalue":   m.pvalues[var],
                    "ci_low":   ci[0],
                    "ci_high":  ci[1],
                    "sig":      ("***" if m.pvalues[var]<0.001
                                 else "**" if m.pvalues[var]<0.01
                                 else "*" if m.pvalues[var]<0.05 else "n.s."),
                    "r2":       m.rsquared,
                    "n_obs":    int(m.nobs),
                })
        # Imprime resultado-chave
        if "post_x_dry" in m.params:
            sig = ("***" if m.pvalues["post_x_dry"]<0.001
                   else "**" if m.pvalues["post_x_dry"]<0.01
                   else "*" if m.pvalues["post_x_dry"]<0.05 else "n.s.")
            console.print(
                f"  [{model_name}] {dep_label}: "
                f"β(Post×Dry)={m.params['post_x_dry']:+.4f} "
                f"(p={m.pvalues['post_x_dry']:.4f}) {sig}"
            )
        return m
    except Exception as e:
        console.print(f"  [red]✗ {model_name} {dep_label}: {e}[/red]")
        return None

