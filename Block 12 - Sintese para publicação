# Classes MapBiomas de vegetação nativa do Cerrado (Collection 9)
NATIVE_CLASSES = [3, 4, 11, 12, 23, 24, 25, 49, 50]

def create_nti_natural_and_export():
    """
    Extrai área queimada em vegetação nativa do Cerrado fora das TIs.

    Estratégia de alto nível:
    1. Cria grid de células de 1° × 1° cobrindo o Cerrado (~120 células)
    2. Aplica máscara: vegetação nativa (MapBiomas LC) + fora das TIs
    3. Para cada ano: reduceRegions() sobre o grid com ee.Reducer.sum()
    4. Cada célula do grid é uma feature → resultado por célula × mês × ano
    5. Soma as células no pós-processamento local

    Vantagens:
    - reduceRegions() é nativo e otimizado do EE
    - Grid de 1° é granularidade suficiente para análise temporal
    - Sem operação vetorial complexa, sem tile manual
    - Todos os anos completos, todos os meses
    """
    years_needed = [y for y in range(START_YEAR, min(END_YEAR, 2023) + 1)
                    if not (EXPORT_LOCAL_NTI / f"{TASK_PREFIX_NTI}_{y}.csv").exists()]

    if not years_needed:
        console.print("  [cyan]✓ NTI natural: todos os anos já exportados.[/cyan]")
        return {}, []

    console.print(f"  Anos a processar: {len(years_needed)}")

    # ── 1. Grid de células 1° × 1° cobrindo o Cerrado ────────────────────────
    tis_fc  = ee.FeatureCollection(EE_ASSET_TIS)
    bounds  = tis_fc.geometry().bounds(maxError=1000)

    # Cria grid 0.25° × 0.25° (~28 km — escala comparável às TIs)
    grid = bounds.coveringGrid(
        proj  = ee.Projection("EPSG:4326").atScale(27830),
        scale = 27830,  # ~0.25° em metros no equador
    )
    console.print(f"  Grid: {grid.size().getInfo()} células de 0.25°×0.25°")

    # ── 2. Máscara: vegetação nativa + fora das TIs ───────────────────────────
    # Rasteriza TIs
    tis_mask = tis_fc.reduceToImage(
        properties=["ti_id"],
        reducer=ee.Reducer.first()
    ).unmask(0).gt(0)
    outside_tis = tis_mask.eq(0)

    # MapBiomas LC Collection 9 — vegetação nativa
    lc = ee.Image(
        "projects/mapbiomas-public/assets/brazil/lulc/collection9/"
        "mapbiomas_collection90_integration_v1"
    )
    lc_2022    = lc.select("classification_2022")
    native_mask = lc_2022.remap(
        NATIVE_CLASSES,
        ee.List.repeat(1, len(NATIVE_CLASSES)),
        0
    )

    # Máscara combinada
    combined_mask = outside_tis.And(native_mask.eq(1))

    # ── 3. MapBiomas Fire ─────────────────────────────────────────────────────
    mapbiomas_fire = ee.Image(
        "projects/mapbiomas-public/assets/brazil/fire/collection3/"
        "mapbiomas_fire_collection3_monthly_burned_coverage_v1"
    )

    # ── 4. Export por ano — reduceRegions() sobre grid ───────────────────────
    tasks = {}
    for year in years_needed:
        band      = f"burned_coverage_{year}"
        month_imgs = []

        for month in range(1, 13):
            burned_month = (
                mapbiomas_fire.select(band)
                .divide(100).floor().toInt()
                .eq(month)
                .updateMask(combined_mask)
                .rename(f"burned_m{month:02d}")
            )
            month_imgs.append(burned_month)

        # Stack todos os 12 meses em uma única imagem multi-banda
        year_img = ee.Image.cat(month_imgs)

        # reduceRegions() sobre o grid — soma de pixels por célula × mês
        reduced = year_img.reduceRegions(
            collection = grid,
            reducer    = ee.Reducer.sum(),
            scale      = 30,
            tileScale  = 4,
        ).map(lambda f: f.set("year", year))

        task = ee.batch.Export.table.toDrive(
            collection     = reduced,
            description    = f"{TASK_PREFIX_NTI}_{year}",
            folder         = EE_EXPORT_NTI,
            fileNamePrefix = f"{TASK_PREFIX_NTI}_{year}",
            fileFormat     = "CSV",
        )
        task.start()
        tasks[year] = task
        console.print(f"  [yellow]→ Task NTI natural: {year}[/yellow]")
        time.sleep(0.3)

    return tasks, years_needed

